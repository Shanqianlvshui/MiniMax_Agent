# Default fake mode is useful for local UI/SSE development without credentials.
# Set this to "minimax" to call the real MiniMax Anthropic-compatible API.
MINIMAX_AGENT_LLM_MODE=fake

# MiniMax official Anthropic-compatible base URL.
# The client posts to ${MINIMAX_BASE_URL}/v1/messages.
MINIMAX_BASE_URL=https://api.minimaxi.com/anthropic
MINIMAX_MODEL=MiniMax-M3
MINIMAX_CONTEXT_WINDOW_TOKENS=1000000
MINIMAX_MAX_OUTPUT_TOKENS=131072
MINIMAX_THINKING=adaptive

# Token Plan key. Do not commit backend/.env with your real key.
MINIMAX_API_KEY=
